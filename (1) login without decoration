<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Вход в аккаунт</title>
</head>
<body>

    <div class="register-card" id="loginCard">
        <h2>Вход в аккаунт</h2>
        <div class="subtitle">Войдите в свою учетную запись</div>
        
        <form id="loginForm">
            <div class="input-group">
                <label>Имя пользователя или Email</label>
                
                </div>
            </div>
            
            <div class="input-group">
                <label>Пароль</label>
                <input type="password" id="loginPassword" placeholder="Введите пароль">
                <div class="error" id="loginPasswordError"></div>
            </div>

            <button type="submit">Войти</button>
        </form>

        <div class="login-link">
            Ещё нет аккаунта? 
            <!-- Ссылка ведет на второй файл регистрации -->
            <a href="register.html" id="showRegisterLink">Зарегистрироваться</a>
        </div>
    </div>

</body>
</html>


