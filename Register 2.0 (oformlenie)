<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Создайте аккаунт</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #0b0f19;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            color: #f0f4f8;
        }

        .register-card {
            background: #111827;
            padding: 40px;
            border-radius: 12px;
            width: 100%;
            max-width: 400px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
            border: 1px solid #1f2937;
        }

        h2 {
            font-size: 28px;
            font-weight: 600;
            margin-bottom: 8px;
            color: #ffffff;
            text-align: center;
        }

        .subtitle {
            font-size: 14px;
            color: #9ca3af;
            margin-bottom: 32px;
            text-align: center;
        }

        .input-group {
            margin-bottom: 20px;
            position: relative;
        }

        label {
            display: block;
            font-size: 13px;
            color: #60a5fa;
            margin-bottom: 8px;
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        input {
            width: 100%;
            padding: 12px 16px;
            background-color: #1f2937;
            border: 1px solid #374151;
            border-radius: 8px;
            color: #ffffff;
            font-size: 15px;
            transition: all 0.3s ease;
        }

        input:focus {
            outline: none;
            border-color: #3b82f6;
            background-color: #111827;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
        }

        input::placeholder {
            color: #4b5563;
        }

        .error {
            color: #ef4444;
            font-size: 12px;
            margin-top: 6px;
            min-height: 18px;
        }

        button {
            width: 100%;
            padding: 14px;
            background-color: #3b82f6;
            color: #ffffff;
            border: none;
            border-radius: 8px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s ease, transform 0.1s ease;
            margin-top: 10px;
        }

        button:hover {
            background-color: #2563eb;
        }

        button:active {
            transform: scale(0.98);
        }

        .login-link {
            text-align: center;
            margin-top: 24px;
            font-size: 14px;
            color: #9ca3af;
        }

        .login-link a {
            color: #60a5fa;
            text-decoration: none;
            font-weight: 500;
            transition: color 0.2s ease;
        }

        .login-link a:hover {
            color: #3b82f6;
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <div class="register-card" id="loginCard">
        <h2>Вход в аккаунт</h2>
        <div class="subtitle">Войдите в свою учетную запись</div>
        
        <form id="loginForm">
            <div class="input-group">
                <label for="loginName">Имя пользователя или электронную почту</label>
                <input type="text" id="loginName" placeholder="Введите Имя или почту от дома">
                <div class="error" id="loginNameError"></div>
            </div>
            
            <div class="input-group">
                <label for="loginPassword">Пароль</label>
                <input type="password" id="loginPassword" placeholder="Введите код от Путина">
                <div class="error" id="loginPasswordError"></div>
            </div>
            
            <div class="error" id="termsError" style="margin-top: -10px; margin-bottom: 20px;"></div>
            
            <button type="submit">Войти</button>
        </form>
        
        <div class="login-link">
            Ещё нет аккаунта? <a href="register.html" id="showRegisterLink">Зарегистрироваться</a>
        </div>
    </div>

</body>
</html>
